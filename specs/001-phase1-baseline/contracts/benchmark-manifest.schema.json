{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "phase1-benchmark-manifest.schema.json",
  "title": "Phase 1 Benchmark Manifest",
  "type": "object",
  "required": [
    "manifest_id",
    "ontology_version",
    "source_ids",
    "split_versions",
    "asset_counts",
    "created_at"
  ],
  "properties": {
    "manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "ontology_version": {
      "type": "string",
      "minLength": 1
    },
    "source_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "split_versions": {
      "type": "object",
      "required": [
        "train",
        "val",
        "test_real_heldout"
      ],
      "properties": {
        "train": {
          "type": "string",
          "minLength": 1
        },
        "val": {
          "type": "string",
          "minLength": 1
        },
        "test_real_heldout": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "asset_counts": {
      "type": "object",
      "required": [
        "train",
        "val",
        "test_real_heldout",
        "by_class"
      ],
      "properties": {
        "train": {
          "type": "integer",
          "minimum": 0
        },
        "val": {
          "type": "integer",
          "minimum": 0
        },
        "test_real_heldout": {
          "type": "integer",
          "minimum": 0
        },
        "by_class": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "additionalProperties": false
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
